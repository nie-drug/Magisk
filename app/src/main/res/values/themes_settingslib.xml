<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Base.Theme.ProjectMaterial3" parent="Theme.GoogleMaterial3.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:textAppearanceListItem">@style/TextAppearance.PreferenceTitle.SettingsLib</item>
        <item name="android:listPreferredItemHeight">72dp</item>
        <item name="android:listPreferredItemPaddingLeft">24dp</item>
        <item name="android:listPreferredItemPaddingRight">16dp</item>
        <item name="android:listPreferredItemPaddingStart">24dp</item>
        <item name="android:listPreferredItemPaddingEnd">16dp</item>
        <item name="android:switchStyle">@style/Switch.SettingsLib</item>
    </style>
    <style name="Switch.SettingsLib" parent="@android:style/Widget.Material.CompoundButton.Switch">
        <item name="android:minHeight">@dimen/settingslib_preferred_minimum_touch_target</item>
        <item name="thumb">@drawable/settingslib_switch_thumb</item>
        <item name="track">@drawable/settingslib_switch_track</item>
        <item name="switchMinWidth">52dp</item>
    </style>
    <style name="PreferenceSummaryTextStyle">
        <item name="android:textAppearance">?android:attr/textAppearanceListItemSecondary</item>
    </style>
    <style name="TextAppearance.PreferenceTitle.SettingsLib" parent="TextAppearance.GoogleMaterial.Headline6">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textSize">20sp</item>
    </style>
    <style name="CollapsingToolbarTitle.Collapsed" parent="TextAppearance.GoogleMaterial.Subhead1">
        <item name="android:textSize">20dip</item>
    </style>
    <style name="CollapsingToolbarTitle.Expanded" parent="TextAppearance.GoogleMaterial.Subhead1">
        <item name="android:textSize">36dip</item>
    </style>
</resources>
